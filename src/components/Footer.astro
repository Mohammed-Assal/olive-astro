---
const logoImage = "/oliveextra-logo.webp";

const quickLinks = ["Home", "About-Us", "Product", "Blog", "Contact"];

const products = [
  "Moroccan wholesale extra virgin olive oil",
  "Wholesale Virgin Olive Oil Moroccan",
  "Organic Olive Oil Morocco Wholesale",
];
---

<footer class="bg-[#1B1B1B] text-white">
  <div class="container mx-auto px-6 py-16">
    <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      {/* Company Info */}
      <div class="space-y-6">
        <img
          src={logoImage}
          alt="Olive Extra - Premium Moroccan Olive Oil Exporter"
          class="h-16 w-auto brightness-0 invert"
        />
        <p class="text-white/70 text-sm">
          Morocco's premier olive oil exporter, delivering premium quality to
          international markets since 2008.
        </p>
        
        <div class="flex space-x-4">
          {/* Instagram */}
          <a
            href="https://www.instagram.com/oliveextra.co"
            aria-label="Follow Olive Extra on Instagram"
            class="bg-white/10 hover:bg-[#B68A45] p-2 rounded-full transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line>
            </svg>
          </a>
        
          {/* LinkedIn */}
          <a
            href="https://www.linkedin.com/company/olive-extra"
            aria-label="Follow Olive Extra on LinkedIn"
            class="bg-white/10 hover:bg-[#B68A45] p-2 rounded-full transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
              <rect x="2" y="9" width="4" height="12"></rect>
              <circle cx="4" cy="4" r="2"></circle>
            </svg>
          </a>
        
          {/* Facebook */}
          <a
            href="https://www.facebook.com/profile.php?id=61585902322132"
            aria-label="Follow Olive Extra on Facebook"
            class="bg-white/10 hover:bg-[#B68A45] p-2 rounded-full transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
            </svg>
          </a>
        
          {/* Pinterest */}
          <a
            href="https://www.pinterest.com/oliveextra/"
            aria-label="Follow Olive Extra on Pinterest"
            class="bg-white/10 hover:bg-[#B68A45] p-2 rounded-full transition-colors"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
            >
              <circle cx="12" cy="12" r="9"></circle>
              <path d="M8 20l4 -9"></path>
              <path d="M10.7 14c.437 1.263 1.43 2 2.55 2 2.071 0 3.75 -1.554 3.75 -4a5 5 0 1 0 -9.7 1.7"></path>
            </svg>
          </a>
        </div>
      </div>

      {/* Quick Links */}
      <div>
        <h4 class="text-white mb-6 text-lg">Quick Links</h4>
        <ul class="space-y-3">
          {
            quickLinks.map((link) => (
              <li>
                <a
                  href={`/${link.toLowerCase()}`}
                  class="text-white/70 hover:text-[#B68A45] transition-colors text-sm"
                >
                  {link}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Products */}
      <div>
        <h4 class="text-white mb-6 text-lg">Our Products</h4>
        <ul class="space-y-3">
          {
            products.map((product) => (
              <li>
                <a
                  href={`/product/${product.toLowerCase().replace(/\s+/g, "-")}`}
                  class="text-white/70 hover:text-[#B68A45] transition-colors text-sm"
                >
                  {product}
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      {/* Contact Info */}
      <div>
        <h4 class="text-white mb-6 text-lg">Contact Us</h4>
        <ul class="space-y-4">
          <li class="flex items-start space-x-3">
            {/* MapPin SVG */}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-[#B68A45] mt-1 flex-shrink-0"
              aria-hidden="true"
              ><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"
              ></path><circle cx="12" cy="10" r="3"></circle></svg
            >
            <span class="text-white/70 text-sm">
              Kelaa Des Sraghna
              <br />
              Morocco
            </span>
          </li>
          <li class="flex items-start space-x-3">
            {/* Phone SVG */}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-[#B68A45] mt-1 flex-shrink-0"
              aria-hidden="true"
              ><path
                d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"
              ></path></svg
            >
            <a
              href="tel:+212708768573"
              class="text-white/70 hover:text-[#B68A45] transition-colors text-sm"
            >
              +212 708768573
            </a>
          </li>
          <li class="flex items-start space-x-3">
            {/* Mail SVG */}
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="20"
              height="20"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="text-[#B68A45] mt-1 flex-shrink-0"
              aria-hidden="true"
              ><rect width="20" height="16" x="2" y="4" rx="2"></rect><path
                d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg
            >
            <a
              href="mailto:helo.olive.extra@gmail.com"
              class="text-white/70 hover:text-[#B68A45] transition-colors text-sm"
            >
              helo.olive.extra@gmail.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    {/* Bottom Bar */}
    <div
      class="border-t border-white/10 pt-8 flex flex-col md:flex-row justify-between items-center space-y-4 md:space-y-0"
    >
      <p class="text-white/60 text-sm">
        © 2026 Olive Extra. All rights reserved.
      </p>
      <div class="flex space-x-6">
        <a
          href="/privacy-policy"
          class="text-white/60 hover:text-[#B68A45] transition-colors text-sm"
        >
          Privacy & Policy
        </a>
        <a
          href="/terms-of-service"
          class="text-white/60 hover:text-[#B68A45] transition-colors text-sm"
        >
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
