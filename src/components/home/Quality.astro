---
// Quality.astro

const certifications = [
  {
    id: 'iso',
    title: 'ISO 22000',
    description: 'Food Safety Management',
  },
  {
    id: 'haccp',
    title: 'HACCP',
    description: 'Hazard Analysis Control',
  },
  {
    id: 'organic',
    title: 'Organic EU',
    description: 'European Organic Certification',
  },
  {
    id: 'lab',
    title: 'Lab Tested',
    description: 'Quality Analysis Reports',
  },
];

const processSteps = [
  { step: '01', title: 'Ancestral Harvest', desc: 'Hand-picked at the exact moment of optimal ripeness to preserve peak acidity.' },
  { step: '02', title: 'Cold Extraction', desc: 'Pressed within hours of harvest using thermal-controlled mechanical means.' },
  { step: '03', title: 'Sensory Testing', desc: 'Rigorous chemical and organoleptic analysis in our certified laboratories.' },
  { step: '04', title: 'Export Packaging', desc: 'Sealed in oxygen-free, food-grade containers to guarantee global transit safety.' },
];
---

<section id="quality" class="py-32 bg-[#414A22] relative overflow-hidden">
  
  {/* Subtle Background Glows */}
  <div class="absolute top-0 right-0 w-[500px] h-[500px] bg-[#BD9343]/5 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>
  <div class="absolute bottom-0 left-0 w-[500px] h-[500px] bg-black/20 rounded-full blur-[120px] pointer-events-none" aria-hidden="true"></div>

  <div class="container mx-auto px-6 max-w-7xl relative z-10">
    
    {/* 1. EDITORIAL HEADER SPLIT */}
    <div class="flex flex-col lg:flex-row justify-between items-end gap-10 mb-24 border-b border-[#FCFBF8]/10 pb-12">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 bg-[#FCFBF8]/5 px-4 py-2 rounded-full mb-8 border border-[#FCFBF8]/10">
          {/* ShieldCheck SVG */}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#BD9343]" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
          <span class="text-[#FCFBF8] text-xs font-black uppercase tracking-[0.3em]">
            Quality Assurance
          </span>
        </div>
        <h2 class="text-[#FCFBF8] text-4xl md:text-6xl font-serif font-medium leading-[1.1]">
          Certified Excellence <br />
          <span class="text-[#BD9343] italic font-light">At Every Drop.</span>
        </h2>
      </div>
      
      <div class="max-w-md lg:pb-2">
        <p class="text-[#FCFBF8]/90 text-lg leading-relaxed font-light">
          Our commitment extends beyond the grove. We maintain rigorous international 
          standards to ensure every shipment delivers the authentic, uncompromised 
          taste of Morocco.
        </p>
      </div>
    </div>

    {/* 2. THE JOURNEY (PROCESS TIMELINE) */}
    <div class="mb-32">
      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-16 relative">
        {/* Desktop Connecting Line */}
        <div class="hidden lg:block absolute top-6 left-0 right-0 h-[1px] bg-gradient-to-r from-[#BD9343]/50 to-transparent" aria-hidden="true"></div>

        {processSteps.map((item) => (
          <div class="relative group">
            {/* Timeline Node */}
            <div class="w-3 h-3 rounded-full bg-[#BD9343] mb-8 relative z-10 shadow-[0_0_15px_rgba(189,147,67,0.5)] group-hover:scale-150 transition-transform duration-500 hidden lg:block" aria-hidden="true"></div>
            
            {/* Big Background Number */}
            <div class="absolute -top-10 -left-4 text-[#FCFBF8]/5 font-serif text-8xl font-bold select-none pointer-events-none group-hover:-translate-y-2 transition-transform duration-500" aria-hidden="true">
              {item.step}
            </div>
            
            <div class="relative z-10 pt-2 lg:pt-0">
              <span class="text-[#BD9343] font-black uppercase tracking-widest text-xs mb-3 block">
                Phase {item.step}
              </span>
              <h3 class="text-[#FCFBF8] text-xl font-serif font-medium mb-4">
                {item.title}
              </h3>
              <p class="text-[#FCFBF8]/90 text-sm leading-relaxed font-light">
                {item.desc}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    {/* 3. CERTIFICATIONS (MINIMALIST SEALS) */}
    <div class="bg-[#FCFBF8]/5 rounded-[3rem] p-10 lg:p-16 border border-[#FCFBF8]/10">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 lg:gap-12">
        {certifications.map((cert) => (
          <div class="flex flex-col items-center text-center group">
            <div class="w-16 h-16 rounded-full bg-[#414A22] border border-[#BD9343]/30 flex items-center justify-center mb-6 group-hover:bg-[#BD9343] transition-colors duration-500 shadow-lg">
              
              {/* Render Icons based on ID */}
              {cert.id === 'iso' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#BD9343] group-hover:text-[#FCFBF8] transition-colors duration-500" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
              {cert.id === 'haccp' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#BD9343] group-hover:text-[#FCFBF8] transition-colors duration-500" aria-hidden="true"><path d="M3.85 8.62a4 4 0 0 1 4.78-4.77 4 4 0 0 1 6.74 0 4 4 0 0 1 4.78 4.78 4 4 0 0 1 0 6.74 4 4 0 0 1-4.77 4.78 4 4 0 0 1-6.75 0 4 4 0 0 1-4.78-4.77 4 4 0 0 1 0-6.76Z"/><path d="m9 12 2 2 4-4"/></svg>
              )}
              {cert.id === 'organic' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#BD9343] group-hover:text-[#FCFBF8] transition-colors duration-500" aria-hidden="true"><path d="M11 20A7 7 0 0 1 14 6c5.5 0 8 2.5 8 2.5s-2.5 8-8 8a7 7 0 0 1-3 10Z"/><path d="m2 22 9-9"/></svg>
              )}
              {cert.id === 'lab' && (
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#BD9343] group-hover:text-[#FCFBF8] transition-colors duration-500" aria-hidden="true"><path d="M10 2v7.527a2 2 0 0 1-.211.896L4.72 20.55a1 1 0 0 0 .9 1.45h12.76a1 1 0 0 0 .9-1.45l-5.069-10.127A2 2 0 0 1 14 9.527V2"/><path d="M8.5 2h7"/><path d="M7 16h10"/></svg>
              )}

            </div>
            <p class="text-[#FCFBF8] font-bold text-sm mb-2">
              {cert.title}
            </p>
            <p class="text-[#FCFBF8]/90 text-xs font-black uppercase tracking-widest">
              {cert.description}
            </p>
          </div>
        ))}
      </div>
    </div>

  </div>
</section>