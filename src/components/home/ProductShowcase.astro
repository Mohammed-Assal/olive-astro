---
// ProductShowcase.astro
// L'data static hna kat-exécuta f Serveur w kat-générer HTML n9i
const products = [
  {
    name: "Extra Virgin Olive Oil",
    grade: "Premium Grade",
    image: "https://res.cloudinary.com/dgcblyg8u/image/upload/v1771003405/jsshobc4fu4t93ffjdec.webp",
    acidity: "< 0.8%",
    features: ["Cold-Pressed", "Organic Certified", "ISO 22000", "First Press"],
    price: "$7.50",
    unit: "per liter",
    minOrder: "500L",
  },
  {
    name: "Virgin Olive Oil",
    grade: "High Quality",
    image: "https://res.cloudinary.com/dgcblyg8u/image/upload/v1770929797/rs5ndbjmxhe7ox17mwdj.webp",
    acidity: "< 2%",
    features: ["Traditional Method", "Quality Tested", "HACCP Certified", "Rich Flavor"],
    price: "$5.00",
    unit: "per liter",
    minOrder: "1000L",
  },
  {
    name: "Organic Olive Oil",
    grade: "Certified Organic",
    image: "https://res.cloudinary.com/dgcblyg8u/image/upload/v1771004390/vulzxbiunlndo2f7qqxw.webp",
    acidity: "< 0.8%",
    features: ["100% Organic", "EU Certified", "Sustainable", "Premium Quality"],
    price: "$9.90",
    unit: "per liter",
    minOrder: "500L",
  },
];
---

<section id="products" class="py-24 bg-[#FCFBF8]">
  <div class="container mx-auto px-6 max-w-7xl">
    {/* 1. SECTION HEADER */}
    <div class="text-center max-w-2xl mx-auto mb-20">
      <div class="inline-flex items-center gap-2 bg-[#414A22]/10 px-4 py-2 rounded-full mb-6">
        {/* Leaf Icon SVG */}
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8A6A27]" aria-hidden="true"><path d="M11 20A7 7 0 0 1 14 6c5.5 0 8 2.5 8 2.5s-2.5 8-8 8a7 7 0 0 1-3 10Z"/><path d="m2 22 9-9"/></svg>
        <span class="text-[#414A22] text-[10px] font-black uppercase tracking-[0.3em]">
          The Collection
        </span>
      </div>
      <h2 class="text-[#111] text-4xl md:text-5xl font-serif font-medium leading-tight mb-6">
        Premium Moroccan <br />
        <span class="text-[#8A6A27] italic font-light">
          Export Selection
        </span>
      </h2>
      <p class="text-[#414A22]/90 text-sm leading-relaxed font-medium">
        Direct wholesale access to Morocco's most prestigious olive oil
        grades, tailored for international distributors and boutique
        retailers.
      </p>
    </div>

    {/* 2. PRODUCTS GRID */}
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-10">
      {products.map((product) => (
        <div class="group flex flex-col bg-white rounded-[2.5rem] overflow-hidden border border-[#414A22]/10 transition-all duration-700 hover:shadow-2xl hover:shadow-[#414A22]/5">
          
          {/* Image Area */}
          <div class="relative h-[320px] overflow-hidden bg-gray-100">
            {/* Tsawer m-optimizyin l'performance: loading="lazy" w decoding="async" darouriyin hna */}
            <img
              src={product.image}
              alt={`Packaging for ${product.name}`}
              loading="lazy"
              decoding="async"
              class="w-full h-full object-cover transition-transform duration-[1.5s] ease-out group-hover:scale-110"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-[#111]/40 via-transparent to-transparent"></div>

            {/* Grade Badge */}
            <div class="absolute top-6 left-6">
              <span class="bg-white/95 backdrop-blur-md px-4 py-1.5 rounded-full text-[9px] font-bold uppercase tracking-widest text-[#414A22] shadow-sm border border-[#414A22]/10">
                {product.grade}
              </span>
            </div>

            <div class="absolute bottom-6 left-6 bg-white/95 backdrop-blur-md px-5 py-2.5 rounded-2xl shadow-sm">
              <p class="text-[#414A22]/80 text-[9px] font-black uppercase tracking-widest mb-0.5">
                Acidity
              </p>
              <p class="text-[#414A22] text-lg font-bold tracking-tight leading-none">
                {product.acidity}
              </p>
            </div>
          </div>

          {/* Content Area */}
          <div class="p-8 flex flex-col flex-grow">
            <h3 class="text-[#111] text-2xl font-serif font-medium mb-6 group-hover:text-[#8A6A27] transition-colors">
              {product.name}
            </h3>

            {/* Features List */}
            <div class="space-y-3 mb-8 flex-grow">
              {product.features.map((feature) => (
                <div class="flex items-center gap-3">
                  <div class="bg-[#414A22]/10 rounded-full p-1">
                    {/* Check Icon SVG */}
                    <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" class="text-[#414A22]"><path d="M20 6 9 17l-5-5"/></svg>
                  </div>
                  <span class="text-[#414A22]/90 text-xs font-bold uppercase tracking-wide">
                    {feature}
                  </span>
                </div>
              ))}
            </div>

            {/* Pricing / Footer */}
            <div class="pt-8 border-t border-[#414A22]/10 mt-auto">
              <div class="flex items-end justify-between mb-8">
                <div class="space-y-1">
                  <p class="text-[#414A22]/70 text-[9px] font-black uppercase tracking-widest">
                    Wholesale
                  </p>
                  <div class="flex items-baseline gap-1">
                    <span class="text-[#414A22] text-3xl font-bold tracking-tighter">
                      {product.price}
                    </span>
                    <span class="text-[#414A22]/80 text-[10px] font-bold uppercase">
                      {product.unit}
                    </span>
                  </div>
                </div>
                <div class="text-right space-y-1">
                  <p class="text-[#414A22]/70 text-[9px] font-black uppercase tracking-widest">
                    Min. Vol
                  </p>
                  <p class="text-[#414A22] text-lg font-bold">
                    {product.minOrder}
                  </p>
                </div>
              </div>

              <a 
                href="/product" 
                aria-label={`View full specifications for ${product.name}`}
                class="w-full py-4 rounded-full border-2 border-[#414A22] text-[#414A22] text-[10px] font-black uppercase tracking-[0.2em] transition-all duration-500 hover:bg-[#414A22] hover:text-white flex items-center justify-center gap-2 group/btn shadow-md active:scale-95"
              >
                See Grade Details
                {/* ArrowRight Icon SVG */}
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="group-hover/btn:translate-x-1 transition-transform" aria-hidden="true"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>