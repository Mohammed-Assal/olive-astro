---
// Features.astro

const features = [
  {
    id: "droplet",
    title: "Cold-Pressed Essence",
    description: "First cold-press extraction preserving all natural nutrients and polyphenols.",
    accent: "#8A6A27", // Darker Gold for accessibility pass
  },
  {
    id: "heart",
    title: "100% Organic Origin",
    description: "Certified pesticide-free cultivation, rooted in pure Moroccan tradition.",
    accent: "#414A22",
  },
  {
    id: "shield",
    title: "Export Certified",
    description: "ISO 22000 & HACCP standards, ensuring global safety compliance.",
    accent: "#8A6A27", 
  },
  {
    id: "zap",
    title: "Direct Logistics",
    description: "Farm-to-port efficiency with flexible wholesale volume options.",
    accent: "#414A22",
  },
];

const certifications = ["ISO 22000", "HACCP", "EU Organic", "ONSSA Morocco"];
const types = ["Extra Virgin", "Organic Bio", "Virgin Grade", "Lampante (Refined)"];
---

<section class="py-32 bg-[#FCFBF8] overflow-hidden">
  <div class="container mx-auto px-6 max-w-7xl">
    <div class="flex flex-col lg:flex-row gap-20 items-start">
      
      {/* 1. LEFT SIDE: Editorial Content & Certs */}
      <div class="lg:w-5/12 sticky top-32">
        <div class="inline-flex items-center gap-2 bg-[#414A22]/10 px-4 py-2 rounded-full mb-8">
          {/* Award Icon */}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#8A6A27]" aria-hidden="true"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89 17 22l-5-3-5 3 1.523-9.11"/></svg>
          <span class="text-[#414A22] text-[10px] font-black uppercase tracking-[0.3em]">
            Uncompromising Standards
          </span>
        </div>

        <h2 class="text-[#111] text-4xl md:text-6xl font-serif font-medium leading-[1.1] mb-10">
          The Science of <br />
          <span class="text-[#8A6A27] italic font-light">
            Liquid Gold.
          </span>
        </h2>

        <p class="text-[#414A22]/90 text-lg leading-relaxed mb-12 font-medium">
          We bridge the gap between ancient Moroccan craftsmanship and
          modern international requirements. Every drop is a testament to
          quality, safety, and transparency.
        </p>

        {/* Certifications List */}
        <div class="grid grid-cols-2 gap-4 border-t border-[#414A22]/20 pt-10">
          {certifications.map((cert) => (
            <div class="flex items-center gap-3">
              <div class="w-2 h-2 rounded-full bg-[#8A6A27]" aria-hidden="true"></div>
              <span class="text-[11px] font-black uppercase tracking-widest text-[#414A22]">
                {cert}
              </span>
            </div>
          ))}
        </div>
      </div>

      {/* 2. RIGHT SIDE: The Creative Grid */}
      <div class="lg:w-7/12 w-full">
        <div class="grid sm:grid-cols-2 gap-6 lg:gap-8">
          {features.map((feature, index) => (
            <div
              class:list={[
                "group relative bg-white p-10 rounded-[2.5rem] border border-[#414A22]/10 transition-all duration-700 hover:shadow-2xl hover:shadow-[#414A22]/10",
                { "lg:translate-y-12": index % 2 !== 0 }
              ]}
            >
              {/* Floating Icon Background */}
              <div
                class="w-16 h-16 rounded-2xl flex items-center justify-center mb-8 transition-all duration-500 group-hover:rotate-[10deg] group-hover:scale-110"
                style={`background-color: ${feature.accent}15; color: ${feature.accent};`}
              >
                {/* SVGs dynamically rendered based on feature.id */}
                {feature.id === 'droplet' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
                )}
                {feature.id === 'heart' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z"/></svg>
                )}
                {feature.id === 'shield' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/></svg>
                )}
                {feature.id === 'zap' && (
                  <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>
                )}
              </div>

              <h3 class="text-[#111] text-xl font-serif font-medium mb-4">
                {feature.title}
              </h3>

              <p class="text-[#414A22]/85 text-sm leading-relaxed mb-6 font-medium">
                {feature.description}
              </p>

              {/* Decorative Background Droplet */}
              <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="absolute bottom-8 right-8 text-[#414A22]/10 group-hover:text-[#8A6A27]/20 transition-colors duration-500" aria-hidden="true"><path d="M12 22a7 7 0 0 0 7-7c0-2-1-3.9-3-5.5s-3.5-4-4-6.5c-.5 2.5-2 4.9-4 6.5C6 11.1 5 13 5 15a7 7 0 0 0 7 7z"/></svg>
            </div>
          ))}
        </div>
      </div>
    </div>

    {/* 3. TRANSITION STRIP */}
    <div class="mt-40 pt-16 border-t border-[#414A22]/20">
      <div class="flex flex-col md:flex-row justify-between items-center gap-8">
        <p class="text-[10px] font-black uppercase tracking-[0.5em] text-[#414A22]/80">
          Full Export Inventory:
        </p>
        <div class="flex flex-wrap justify-center gap-x-12 gap-y-4">
          {types.map((type) => (
            <span class="text-[#414A22] font-serif italic text-xl md:text-2xl opacity-90 hover:opacity-100 hover:text-[#8A6A27] transition-all cursor-default">
              {type}
            </span>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>