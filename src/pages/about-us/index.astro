---
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import '../../styles/global.css'
// src/pages/about-us.astro


// SEO Variables
const title = "About Olive Extra | Our Moroccan Heritage & Wholesale Mission";
const description = "Discover the story behind Olive Extra. We bridge the gap between Morocco’s ancient olive groves and global markets, providing premium, cold-pressed bulk EVOO to professional buyers.";
const keywords = "About Olive Extra, Moroccan olive oil history, olive oil production Morocco, bulk olive oil sourcing, extra virgin olive oil heritage, direct-from-farm olive oil, Olive Extra company profile";
const siteUrl = "https://www.oliveextra.com/about-us";
const imageUrl = "https://www.oliveextra.com/olive-extra-logo.webp";

// JSON-LD (Structured Data) l Google
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WholesaleStore",
  "name": "Olive Extra",
  "image": "https://www.oliveextra.com/olive-extra-logo.webp",
  "logo": "https://www.oliveextra.com/olive-extra-logo.webp",
  "description": "Premium wholesale supplier of Moroccan Extra Virgin Olive Oil.",
  "address": {
    "@type": "PostalAddress",
    "addressLocality": "Kelaa Des Sraghna",
    "addressCountry": "MA"
  },
  "url": "https://www.oliveextra.com",
  "telephone": "+212708768573",
  "knowsAbout": [
    "Extra Virgin Olive Oil",
    "Moroccan Agriculture",
    "Wholesale Supply Chain"
  ],
  "contactPoint": {
    "@type": "ContactPoint",
    "telephone": "+212708768573",
    "contactType": "sales",
    "areaServed": "Global",
    "availableLanguage": ["English", "French", "Arabic"]
  }
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    {/* Basic SEO */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Olive Extra Team" />
    <meta name="robots" content="index, follow, max-image-preview:large" />
    <link rel="canonical" href={siteUrl} />

    {/* OpenGraph */}
    <meta property="og:title" content="The Story of Olive Extra | Premium Moroccan EVOO" />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Olive Extra" />
    <meta property="og:type" content="article" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Traditional Moroccan Olive Groves - Olive Extra" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="About Us | Olive Extra Moroccan Olive Oil" />
    <meta name="twitter:description" content="Authentic, cold-pressed Moroccan olive oil supplied in bulk worldwide." />
    <meta name="twitter:image" content={imageUrl} />
    
    {/* Favicon */}
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />

    {/* Injection dyal JSON-LD b tari9a s7i7a f Astro */}
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  
  <body class="bg-[#FEFAE0] text-[#283618] font-sans min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-grow mt-24">
      {/* Hero Section */}
      {/* Mola7ada: bdlna py-29 l py-28 7it py-29 makaynach f Tailwind par défaut */}
      <section class="relative py-28 px-6 text-center bg-white border-b border-gray-100">
        <div class="max-w-4xl mx-auto">
          <span class="text-[#606C38] font-bold tracking-widest uppercase text-sm">
            Our Heritage
          </span>
          <h1 class="text-4xl md:text-6xl font-serif mt-4 mb-6">
            Pure Moroccan Gold, <br />
            <span class="text-[#DDA15E]">From Grove to Table.</span>
          </h1>
          <p class="text-lg text-gray-600 leading-relaxed max-w-2xl mx-auto">
            Olive Extra is a leading supplier of premium extra virgin olive oil,
            connecting the ancient groves of Morocco to retailers and
            professional buyers worldwide.
          </p>
        </div>
      </section>

      {/* Values Section */}
      <section class="py-16 px-6 max-w-7xl mx-auto">
        <div class="grid md:grid-cols-3 gap-12 text-center">
          <div>
            <div class="w-16 h-16 bg-[#606C38] rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">100% Natural</h3>
            <p class="text-gray-600">
              Pure, cold-pressed juice from Moroccan olives. No additives, no
              blends, no compromises.
            </p>
          </div>
          <div>
            <div class="w-16 h-16 bg-[#DDA15E] rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Bulk Efficiency</h3>
            <p class="text-gray-600">
              Streamlined logistics for wholesale, restaurants, and professional
              kitchens at scale.
            </p>
          </div>
          <div>
            <div class="w-16 h-16 bg-[#283618] rounded-full flex items-center justify-center mx-auto mb-6">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold mb-3">Global Quality</h3>
            <p class="text-gray-600">
              Sourced from the heart of Morocco, meeting the highest
              international culinary standards.
            </p>
          </div>
        </div>
      </section>

      {/* Narrative Section */}
      <section class="bg-[#606C38] text-white py-20 px-6">
        <div class="max-w-5xl mx-auto flex flex-col md:flex-row items-center gap-12">
          <div class="md:w-1/2">
            <h2 class="text-3xl font-serif mb-6 italic">
              The Art of Cold Extraction
            </h2>
            <p class="mb-4 leading-relaxed">
              At Olive Extra, we believe that the best olive oil is a product of
              patience and respect for nature. Our olives are carefully selected
              at the peak of ripeness and cold-pressed within hours of harvest.
            </p>
            <p class="leading-relaxed">
              This process preserves the rich antioxidants, vibrant green color,
              and that signature peppery finish that Moroccan Extra Virgin Olive
              Oil is famous for.
            </p>
          </div>
          <div class="md:w-1/2 bg-[#DDA15E] p-8 rounded-lg shadow-xl">
            <h3 class="text-2xl font-bold mb-4">Our Commitment</h3>
            <ul class="space-y-4">
              <li class="flex items-start gap-3">
                <span class="font-bold">•</span>
                <span>
                  Traceability from Moroccan groves to your warehouse.
                </span>
              </li>
              <li class="flex items-start gap-3">
                <span class="font-bold">•</span>
                <span>Rigid quality control for every bulk shipment.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="font-bold">•</span>
                <span>Sustainable farming practices.</span>
              </li>
            </ul>
          </div>
        </div>
      </section>

      {/* CTA Section */}
      <section class="py-20 text-center">
        <h2 class="text-3xl font-serif mb-8">
          Ready to elevate your supply chain?
        </h2>
        <a
          href="/contact"
          class="inline-block bg-[#283618] text-white px-10 py-4 rounded-full font-bold hover:bg-[#606C38] transition-colors shadow-lg"
        >
          Request Wholesale Catalog
        </a>
      </section>
    </main>

    <Footer />
  </body>
</html>