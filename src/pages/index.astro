---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import Hero from "../components/home/Hero.astro";
import CTA from "../components/home/CTA.astro";
import ProductShowcase from "../components/home/ProductShowcase.astro";
import About from "../components/home/About.astro";
import Quality from "../components/home/Quality.astro";
import Features from "../components/home/Features.astro";

// SEO Metadata Variables
const seo = {
  title: "Olive Extra | Wholesale Extra Virgin Olive Oil from Morocco",
  description: "Olive Extra supplies premium extra virgin olive oil in wholesale and bulk quantities. Produced from carefully selected Moroccan olives, cold-pressed, 100% natural, ideal for retailers, restaurants, and professional buyers.",
  keywords: "wholesale olive oil, bulk olive oil, extra virgin olive oil wholesale, Moroccan olive oil supplier, cold pressed olive oil, Mediterranean olive oil, olive oil in bulk, Olive Extra",
  author: "Olive Extra",
  robots: "index, follow",
  canonical: "https://www.oliveextra.com/",
  openGraph: {
    title: "Olive Extra | Wholesale Extra Virgin Olive Oil",
    description: "Premium Moroccan extra virgin olive oil available in wholesale and bulk quantities. Cold-pressed, natural quality for professional and commercial use.",
    url: "https://www.oliveextra.com/",
    siteName: "Olive Extra",
    type: "website",
    locale: "en_US",
    image: "https://www.oliveextra.com/oliveextra-logo.webp",
    imageWidth: "1200",
    imageHeight: "630",
    imageAlt: "Olive Extra Wholesale Extra Virgin Olive Oil from Morocco",
  },
  twitter: {
    card: "summary_large_image",
    title: "Olive Extra | Wholesale Olive Oil Supplier",
    description: "Wholesale supplier of premium Moroccan extra virgin olive oil. Bulk quantities, cold-pressed, natural quality.",
    image: "https://www.oliveextra.com/oliveextra-logo.webp",
    creator: "@OliveExtra",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <!-- Essential Meta Tags -->
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seo.title}</title>
    <meta name="description" content={seo.description} />
    
    <!-- Standard SEO Meta Tags -->
    <meta name="keywords" content={seo.keywords} />
    <meta name="author" content={seo.author} />
    <meta name="robots" content={seo.robots} />
    <link rel="canonical" href={seo.canonical} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={seo.openGraph.type} />
    <meta property="og:url" content={seo.openGraph.url} />
    <meta property="og:title" content={seo.openGraph.title} />
    <meta property="og:description" content={seo.openGraph.description} />
    <meta property="og:site_name" content={seo.openGraph.siteName} />
    <meta property="og:locale" content={seo.openGraph.locale} />
    <meta property="og:image" content={seo.openGraph.image} />
    <meta property="og:image:width" content={seo.openGraph.imageWidth} />
    <meta property="og:image:height" content={seo.openGraph.imageHeight} />
    <meta property="og:image:alt" content={seo.openGraph.imageAlt} />

    <!-- Twitter -->
    <meta name="twitter:card" content={seo.twitter.card} />
    <meta name="twitter:title" content={seo.twitter.title} />
    <meta name="twitter:description" content={seo.twitter.description} />
    <meta name="twitter:image" content={seo.twitter.image} />
    <meta name="twitter:creator" content={seo.twitter.creator} />
    <meta name="twitter:site" content={seo.twitter.creator} />
  </head>
  <body>
    <Header />
    <Hero />
    <ProductShowcase />
    <Features />
    <About />
    <Quality />
    <CTA />
    <Footer />
  </body>
</html>