---
// src/pages/terms-of-service.astro
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import '../../styles/global.css';

// SEO Variables
const title = "Terms of Service | Olive Extra – Wholesale & Export Moroccan Olive Oil";
const description = "Read Olive Extra's Terms of Service for wholesale and international orders of premium Moroccan olive oil. Learn about commercial account responsibilities, export compliance, and legal policies.";
const keywords = "terms of service, Olive Extra terms, wholesale olive oil, export olive oil, Moroccan olive oil, commercial accounts, international orders, Olive Extra policies";
const siteUrl = "https://www.oliveextra.com/terms-of-service";
const imageUrl = "https://www.oliveextra.com/oliveextra-logo.webp";
const lastUpdated = "December 22, 2025";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    
    {/* Basic SEO */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Olive Extra Team" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    {/* OpenGraph */}
    <meta property="og:title" content="Terms of Service | Olive Extra – Wholesale Moroccan Olive Oil" />
    <meta property="og:description" content="Comprehensive Terms of Service for wholesale buyers and international customers of Olive Extra's premium Moroccan olive oil. Transparency and trust guaranteed." />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Olive Extra" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Olive Extra Terms of Service – Wholesale Moroccan Olive Oil" />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Terms of Service | Olive Extra" />
    <meta name="twitter:description" content="Read Olive Extra's Terms of Service for wholesale and export orders of premium Moroccan olive oil." />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:creator" content="@OliveExtra" />

    {/* Favicon */}
    <link rel="icon" type="image/webp" href="/olive-extra-logo.webp" />
  </head>

  <body class="bg-[#FCFBFA] min-h-screen flex flex-col">
    <Header />
    
    <main class="flex-grow pt-32 pb-20">
      <div class="container mx-auto px-6">
        <article class="max-w-5xl mx-auto bg-white shadow-sm border border-gray-100 rounded-3xl overflow-hidden">
          
          {/* Hero Section */}
          <header class="bg-[#4A512E] p-12 text-white">
            <div class="flex items-center gap-3 mb-4 opacity-80">
              {/* FileText SVG */}
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"/><path d="M14 2v4a2 2 0 0 0 2 2h4"/><path d="M10 9H8"/><path d="M16 13H8"/><path d="M16 17H8"/></svg>
              <span class="uppercase tracking-widest text-xs font-bold">Legal Department</span>
            </div>
            <h1 class="text-4xl md:text-5xl font-bold font-serif mb-4">
              Terms of Service
            </h1>
            <p class="text-white/80 max-w-2xl text-lg">
              Please read these terms carefully before using our platform or placing wholesale orders.
              By accessing Olive Extra, you agree to be bound by these legal conditions.
            </p>
            <div class="mt-8 pt-8 border-t border-white/10 flex flex-wrap gap-6 text-sm">
              <span><strong>Last Updated:</strong> {lastUpdated}</span>
              <span><strong>Version:</strong> 2.0.4</span>
              <span><strong>Jurisdiction:</strong> Morocco</span>
            </div>
          </header>

          {/* Quick Summary Grid */}
          <section class="p-8 md:p-16">
            <div class="grid md:grid-cols-3 gap-8 mb-16">
              <div class="flex flex-col gap-3 p-6 bg-[#F7F5EF] rounded-2xl">
                {/* Globe SVG */}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#B68A45]" aria-hidden="true"><circle cx="12" cy="12" r="10"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/><path d="M2 12h20"/></svg>
                <h2 class="font-bold text-[#1B1B1B]">Global Export</h2>
                <p class="text-xs text-[#4A512E]">Rules for international logistics and customs.</p>
              </div>
              <div class="flex flex-col gap-3 p-6 bg-[#F7F5EF] rounded-2xl">
                {/* ShieldCheck SVG */}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#B68A45]" aria-hidden="true"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.5 3.8 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/></svg>
                <h2 class="font-bold text-[#1B1B1B]">Data Security</h2>
                <p class="text-xs text-[#4A512E]">Protection of commercial and payment data.</p>
              </div>
              <div class="flex flex-col gap-3 p-6 bg-[#F7F5EF] rounded-2xl">
                {/* Scale SVG */}
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-[#B68A45]" aria-hidden="true"><path d="m16 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="m2 16 3-8 3 8c-.87.65-1.92 1-3 1s-2.13-.35-3-1Z"/><path d="M7 21h10"/><path d="M12 3v18"/><path d="M3 7h2c2 0 5-1 7-2 2 1 5 2 7 2h2"/></svg>
                <h2 class="font-bold text-[#1B1B1B]">Resolution</h2>
                <p class="text-xs text-[#4A512E]">Procedures for handling disputes or returns.</p>
              </div>
            </div>

            {/* Main Legal Content */}
            <div class="prose prose-slate max-w-none prose-headings:text-[#1B1B1B] prose-headings:font-serif prose-p:text-[#4A512E] prose-p:leading-8 prose-p:mb-6 prose-strong:text-[#1B1B1B] prose-li:text-[#4A512E]">
              
              <section>
                <h2>1. Acceptance of Terms</h2>
                <p>
                  The services provided by Olive Extra (referred to as "the Company," "we," or "us") 
                  via oliveextra.com are subject to these Terms of Service. We may update them at any time. 
                  The latest version is always available via the "Terms of Service" link on our website.
                </p>
              </section>

              <hr class="my-10 border-gray-100" />

              <section>
                <h2>2. Commercial Wholesale Accounts</h2>
                <p>
                  Wholesale or export account holders are responsible for their account security. 
                  Olive Extra may refuse service, terminate accounts, or cancel orders at its discretion.
                </p>
              </section>

              <section>
                <h2>3. International Shipping & Export Controls</h2>
                <ul>
                  <li><strong>Incoterms:</strong> Exports handled under EXW or FOB unless agreed otherwise.</li>
                  <li><strong>Documentation:</strong> Standard phytosanitary certificates and certificates of origin are provided. Additional country-specific documents must be requested at order time.</li>
                  <li><strong>Compliance:</strong> Buyers must ensure import compliance with local laws and regulations.</li>
                </ul>
              </section>

              <section>
                <h2>4. Pricing and Payment</h2>
                <p>
                  Prices may vary due to market fluctuations. Official quotes are valid for 14 days. Payments must be via Wire Transfer (SWIFT) or confirmed Letter of Credit unless otherwise authorized.
                </p>
              </section>

              <section>
                <h2>5. Intellectual Property Rights</h2>
                <p>
                  All site content, including text, images, and downloads, belongs to Olive Extra or its suppliers and is protected under Moroccan and international copyright laws.
                </p>
              </section>

              <section>
                <h2>6. Limitation of Liability</h2>
                <p>
                  Olive Extra is not liable for indirect, incidental, or consequential damages. Total liability is limited to the amount paid for the specific order.
                </p>
              </section>

              <section>
                <h2>7. Governing Law</h2>
                <p>
                  These terms are governed by Moroccan law. The courts in Marrakesh have exclusive jurisdiction over disputes.
                </p>
              </section>

              <section class="bg-[#F7F5EF] p-8 rounded-2xl border-l-4 border-[#B68A45] mt-12">
                <h3 class="text-xl font-bold mb-2 mt-0">Questions regarding Terms?</h3>
                <p class="mb-0 italic">
                  For a signed copy of our commercial terms, contact <strong>helo.olive.extra@gmail.com</strong>.
                </p>
              </section>
            </div>
          </section>
        </article>
      </div>
    </main>
    
    <Footer />
  </body>
</html>