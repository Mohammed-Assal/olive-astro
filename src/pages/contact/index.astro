---
// src/pages/contact.astro
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import CTA from "../../components/home/CTA.astro";
import "../../styles/global.css"; 

// SEO Variables (kima kano f metadata dyal Next.js)
const title = "Contact Olive Extra | Premium Moroccan Olive Oil Supplier";
const description =
  "Get in touch with Olive Extra, a premium Moroccan olive oil supplier. Contact us for wholesale inquiries, product information, or any questions about our high-quality extra virgin olive oil.";
const keywords =
  "Olive Extra contact, Moroccan olive oil supplier, wholesale olive oil contact, extra virgin olive oil inquiries, Olive Extra support";
const siteUrl = "https://www.oliveextra.com/contact";
const imageUrl = "https://www.oliveextra.com/oliveextra-logo.webp";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    {/* Basic SEO */}
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content={keywords} />
    <meta name="author" content="Olive Extra Team" />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={siteUrl} />

    {/* OpenGraph (Facebook/LinkedIn) */}
    <meta
      property="og:title"
      content="Contact Olive Extra | Moroccan Olive Oil Supplier"
    />
    <meta
      property="og:description"
      content="Reach Olive Extra for wholesale orders, product details, or questions about premium Moroccan extra virgin olive oil."
    />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:site_name" content="Olive Extra" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="en_US" />
    <meta property="og:image" content={imageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta
      property="og:image:alt"
      content="Contact Olive Extra – Moroccan Olive Oil Supplier"
    />

    {/* Twitter */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta
      name="twitter:title"
      content="Contact Olive Extra | Moroccan Olive Oil Supplier"
    />
    <meta
      name="twitter:description"
      content="Contact Olive Extra for wholesale orders, product information, or questions about premium Moroccan extra virgin olive oil."
    />
    <meta name="twitter:image" content={imageUrl} />
    <meta name="twitter:creator" content="@OliveExtra" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
  </head>

  <body class="bg-[#FCFBF8] min-h-screen flex flex-col">
    <Header />

    <main class="flex-grow mt-24">
      <CTA />
    </main>

    <Footer />
  </body>
</html>
